# Eva-Core configuration. Copy to `.env` and fill in the keys you have.
# Any provider without a key is simply marked "unavailable"; the server still runs.

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# --- x.ai (Grok) ---
XAI_API_KEY=
XAI_MODEL=grok-2-latest
# XAI_BASE_URL=https://api.x.ai/v1

# --- Google GenAI (Gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Anthropic Claude ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Azure Cognitive Services Speech ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_VOICE=en-US-AvaMultilingualNeural

# --- Server ---
HOST=0.0.0.0
PORT=8000
